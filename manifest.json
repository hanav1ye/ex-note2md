{
  "manifest_version": 3,
  "name": "note to Markdown",
  "version": "1.0.0",
  "description": "note.com の記事を Markdown に変換します（画像のダウンロードは行いません）。",
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "host_permissions": ["https://note.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "note → Markdown",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://note.com/*"],
      "js": ["lib/noteToMarkdown.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
